"""
mock_anthropic.py
-----------------
Simula a API da Anthropic SEM precisar de API key ou créditos.
Imita a mesma estrutura da API real: mensagens, roles, system prompt,
tool_use e streaming. As respostas são geradas localmente.

Quando você tiver créditos, troca este mock pelo cliente real:
    from anthropic import Anthropic
    client = Anthropic()
...e o resto do código quase não muda. Essa é a ideia.
"""

import time
import random


class _Bloco:
    def __init__(self, texto):
        self.type = "text"
        self.text = texto


class _Resposta:
    def __init__(self, texto, model, input_tokens, output_tokens):
        self.content = [_Bloco(texto)]
        self.model = model
        self.role = "assistant"
        self.stop_reason = "end_turn"
        self.usage = type("Usage", (), {
            "input_tokens": input_tokens,
            "output_tokens": output_tokens
        })()


def _contar_tokens(texto):
    return max(1, len(texto) // 4)


def _gerar_resposta_falsa(messages, system):
    ultima = ""
    for m in messages:
        if m["role"] == "user":
            ultima = m["content"] if isinstance(m["content"], str) else str(m["content"])

    persona = f" [persona ativa: {system[:40]}...]" if system else ""
    respostas = [
        f"(resposta simulada){persona} Você disse: '{ultima}'. "
        f"Na API real, eu responderia de verdade aqui.",
        f"(mock){persona} Entendi sua mensagem sobre '{ultima[:30]}'. "
        f"Esta resposta foi gerada localmente, sem gastar créditos.",
    ]
    return random.choice(respostas)


class _Messages:
    def create(self, model, max_tokens, messages, system="", **kwargs):
        texto = _gerar_resposta_falsa(messages, system)
        texto = texto[: max_tokens * 4]
        entrada = sum(_contar_tokens(str(m["content"])) for m in messages)
        entrada += _contar_tokens(system)
        saida = _contar_tokens(texto)
        return _Resposta(texto, model, entrada, saida)

    def stream(self, model, max_tokens, messages, system="", **kwargs):
        texto = _gerar_resposta_falsa(messages, system)
        return _Stream(texto)


class _Stream:
    def __init__(self, texto):
        self.texto = texto

    def __enter__(self):
        return self

    def __exit__(self, *args):
        return False

    @property
    def text_stream(self):
        for palavra in self.texto.split(" "):
            time.sleep(0.05)
            yield palavra + " "


class Anthropic:
    def __init__(self, *args, **kwargs):
        self.messages = _Messages()